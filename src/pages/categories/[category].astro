---
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, slugify } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  const categories = [...new Set(posts.map((post) => post.data.category))];
  return categories.map((category) => ({ params: { category: slugify(category) }, props: { category } }));
}

const { category } = Astro.props;
const posts = (await getPosts()).filter((post) => post.data.category === category);
---
<BaseLayout title={category} description={`Articles about ${category}.`}>
  <section class="container section">
    <h1>{category}</h1>
    <div class="grid">{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>
