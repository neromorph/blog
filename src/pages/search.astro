---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search" description="Search articles by title, description, category, or tag.">
  <section class="reading section">
    <h1>Search</h1>
    <input class="search-box" type="search" placeholder="Search articles…" aria-label="Search articles" data-search />
    <div data-results class="section"></div>
  </section>
  <script>
    type SearchPost = {
      title: string;
      description: string;
      category: string;
      tags: string[];
      url: string;
    };

    const input = document.querySelector('[data-search]') as HTMLInputElement;
    const results = document.querySelector('[data-results]') as HTMLDivElement;
    const posts: SearchPost[] = await fetch('/search.json').then((res) => res.json());
    const params = new URLSearchParams(location.search);
    input.value = params.get('q') ?? '';
    const render = () => {
      const query = input.value.toLowerCase().trim();
      const matches = query
        ? posts.filter((post) => [post.title, post.description, post.category, ...post.tags].join(' ').toLowerCase().includes(query))
        : [];
      results.innerHTML = matches.map((post) => `<article class="post-card"><h2><a href="${post.url}">${post.title}</a></h2><p>${post.description}</p></article>`).join('') || (query ? '<p>No articles found.</p>' : '');
    };
    input.addEventListener('input', render);
    render();
  </script>
</BaseLayout>
