---
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, slugify } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
  return tags.map((tag) => ({ params: { tag: slugify(tag) }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = (await getPosts()).filter((post) => post.data.tags.includes(tag));
---
<BaseLayout title={`#${tag}`} description={`Articles tagged ${tag}.`}>
  <section class="container section">
    <h1>#{tag}</h1>
    <div class="grid">{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>
